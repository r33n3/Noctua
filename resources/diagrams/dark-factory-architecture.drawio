        <mxCell id="p4-g2-drift" parent="1" vertex="1" style="rounded=1;arcSize=8;fillColor=#1A1200;strokeColor=#F59E0B;strokeWidth=2;fontColor=#F59E0B;fontSize=9;align=left;spacingLeft=8;">
