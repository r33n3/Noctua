        <mxCell id="p4-g2-note" parent="1" vertex="1" style="rounded=1;arcSize=6;fillColor=#0B0F1A;strokeColor=#334155;fontColor=#64748B;fontSize=8;align=left;spacingLeft=8;">
          <mxGeometry x="545" y="527" width="370" height="51" as="geometry" />
          <UserObject label="&lt;b style='color:#94A3B8'&gt;Key property:&lt;/b&gt; Drift detection is async — zero latency on hot path. Hard guardrails remain synchronous. SPEC.md is the behavioral contract: same document Harbor uses for correctness eval." />
        </mxCell>

        <!-- ── GATE 3: DELIVERY ── -->
        <mxCell id="p4-g3-bg" parent="1" vertex="1"
