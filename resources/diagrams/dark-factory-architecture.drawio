  ═══════════════════════════════════════════════════════════════════ -->
  <diagram id="p2-resilience" name="Resilience Architecture">
    <mxGraphModel grid="1" gridSize="10" pageWidth="1540" pageHeight="730">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="p2-title-bg" parent="1" vertex="1"
          style="rounded=1;arcSize=3;fillColor=#0B0F1A;strokeColor=#3730A3;strokeWidth=2;"
          value="">
          <mxGeometry x="40" y="10" width="1460" height="52" as="geometry" />
        </mxCell>
        <mxCell id="p2-title" parent="1" vertex="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;fontColor=#E2E8F0;">
          <mxGeometry x="40" y="13" width="1460" height="26" as="geometry" />
          <UserObject label="Resilience Architecture — Target State" />
        </mxCell>
        <mxCell id="p2-sub" parent="1" vertex="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=9;fontColor=#64748B;">
          <mxGeometry x="40" y="40" width="1460" height="16" as="geometry" />
          <UserObject label="If PeaRL goes down, the factory halts gracefully — by design. No rogue agents run without governance. Halt is a feature." />
        </mxCell>

        <!-- ── TIER 1: ACTIVE-ACTIVE ── -->
        <mxCell id="p2-t1-bg" parent="1" vertex="1"
          style="rounded=1;arcSize=2;fillColor=#030A06;strokeColor=#10B981;strokeWidth=2;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#10B981;spacingTop=6;"
          value="◆  ACTIVE-ACTIVE">
          <mxGeometry x="40" y="70" width="350" height="510" as="geometry" />
        </mxCell>
        <mxCell id="p2-pearl-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#0D2010;strokeColor=#10B981;strokeWidth=2;fontColor=#E2E8F0;fontSize=10;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="55" y="100" width="320" height="120" as="geometry" />
          <UserObject label="&lt;b style='font-size:11px'&gt;PeaRL&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;2-node active-active · shared PostgreSQL · Redis&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; a node goes down&lt;br/&gt;&lt;b&gt;Recovery:&lt;/b&gt; traffic shifts instantly, no state loss&lt;br/&gt;PostgreSQL is source of truth — no node-local state&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-pg-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#0D2010;strokeColor=#10B981;strokeWidth=2;fontColor=#E2E8F0;fontSize=10;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="55" y="232" width="320" height="110" as="geometry" />
          <UserObject label="&lt;b style='font-size:11px'&gt;PostgreSQL (Patroni)&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;streaming replica · auto-failover&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; primary dies&lt;br/&gt;&lt;b&gt;Recovery:&lt;/b&gt; Patroni promotes standby in &amp;lt;30s&lt;br/&gt;Agents resume on next heartbeat&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-redis-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#0D2010;strokeColor=#10B981;strokeWidth=2;fontColor=#E2E8F0;fontSize=10;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="55" y="354" width="320" height="100" as="geometry" />
          <UserObject label="&lt;b style='font-size:11px'&gt;Redis Cluster&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;multi-shard · automatic shard promotion&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; primary shard fails&lt;br/&gt;&lt;b&gt;Recovery:&lt;/b&gt; cluster promotes replica, no data loss&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-t1-note" parent="1" vertex="1"
          style="rounded=1;arcSize=6;fillColor=#052E16;strokeColor=#10B981;strokeWidth=1;fontColor=#94A3B8;fontSize=8;align=left;spacingLeft=8;">
          <mxGeometry x="55" y="466" width="320" height="100" as="geometry" />
          <UserObject label="&lt;b style='color:#34D399'&gt;On total control-plane failure:&lt;/b&gt;&lt;br/&gt;Agents pause at @before_model on the next turn — check_message_queue returns unavailable. No agent continues without governance. Delivery halts cleanly." />
        </mxCell>

        <!-- ── TIER 2: HA CONTROLLED ── -->
        <mxCell id="p2-t2-bg" parent="1" vertex="1"
          style="rounded=1;arcSize=2;fillColor=#0D0800;strokeColor=#F59E0B;strokeWidth=2;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#F59E0B;spacingTop=6;"
          value="◆  HA CONTROLLED">
          <mxGeometry x="410" y="70" width="680" height="510" as="geometry" />
        </mxCell>
        <!-- Row 1: LiteLLM, Vault, SPIRE -->
        <mxCell id="p2-ll-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#1A1200;strokeColor=#F59E0B;strokeWidth=2;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="425" y="100" width="210" height="130" as="geometry" />
          <UserObject label="&lt;b style='font-size:10px'&gt;LiteLLM&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;2× instances · nginx/HAProxy LB&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; instance crash&lt;br/&gt;&lt;b&gt;Recovery:&lt;/b&gt; LB routes to survivor&lt;br/&gt;&lt;b&gt;Model fallback:&lt;/b&gt;&lt;br/&gt;Nemotron → Claude API&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-vault-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#1A1200;strokeColor=#F59E0B;strokeWidth=2;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="645" y="100" width="210" height="130" as="geometry" />
          <UserObject label="&lt;b style='font-size:10px'&gt;Vault&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;Raft 3-node integrated cluster&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; node fails&lt;br/&gt;&lt;b&gt;Recovery:&lt;/b&gt; Raft elects leader &amp;lt;10s&lt;br/&gt;Pipeline pauses briefly&lt;br/&gt;then resumes automatically&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-spire-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#1A1200;strokeColor=#F59E0B;strokeWidth=2;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="865" y="100" width="210" height="130" as="geometry" />
          <UserObject label="&lt;b style='font-size:10px'&gt;SPIFFE/SPIRE&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;clustered server · shared datastore&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; server crash&lt;br/&gt;&lt;b&gt;Recovery:&lt;/b&gt; cluster peer takes over&lt;br/&gt;In-flight SVIDs stay valid&lt;br/&gt;until TTL expiry&lt;/font&gt;" />
        </mxCell>
        <!-- Row 2: MASS, Harbor, Nexus -->
        <mxCell id="p2-mass-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#1A1200;strokeColor=#F59E0B;strokeWidth=2;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="425" y="244" width="210" height="140" as="geometry" />
          <UserObject label="&lt;b style='font-size:10px'&gt;MASS 2.0&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;restart:always · health endpoint&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; process crash&lt;br/&gt;&lt;b&gt;Recovery:&lt;/b&gt; auto-restart &amp;lt;5s&lt;br/&gt;Gate waits with timeout&lt;br/&gt;&lt;b&gt;Override:&lt;/b&gt; signed human approval&lt;br/&gt;→ PeaRL mandatory audit log&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-harbor-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#1A1200;strokeColor=#F59E0B;strokeWidth=2;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="645" y="244" width="210" height="140" as="geometry" />
          <UserObject label="&lt;b style='font-size:10px'&gt;deepagents-harbor&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;restart:always · health endpoint&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; process crash&lt;br/&gt;&lt;b&gt;Recovery:&lt;/b&gt; auto-restart &amp;lt;5s&lt;br/&gt;Gate waits with timeout&lt;br/&gt;&lt;b&gt;Override:&lt;/b&gt; signed human approval&lt;br/&gt;→ PeaRL mandatory audit log&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-nexus-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#1A1200;strokeColor=#F59E0B;strokeWidth=2;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="865" y="244" width="210" height="140" as="geometry" />
          <UserObject label="&lt;b style='font-size:10px'&gt;Nexus OSS&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;warm-restart · agent retry+backoff&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; service outage&lt;br/&gt;&lt;b&gt;Recovery:&lt;/b&gt; disk cache survives restart&lt;br/&gt;Agents retry with exp. backoff&lt;br/&gt;Most outages resolve &amp;lt;30s&lt;/font&gt;" />
        </mxCell>
        <!-- Row 3: Nemotron (full width) + MinIO -->
        <mxCell id="p2-nem-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#1A1200;strokeColor=#F59E0B;strokeWidth=2;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="425" y="398" width="430" height="90" as="geometry" />
          <UserObject label="&lt;b style='font-size:10px'&gt;Nemotron NIM (GPU Server)&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;LiteLLM fallback routing rule configured&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; GPU server down&lt;br/&gt;&lt;b&gt;Recovery:&lt;/b&gt; LiteLLM routes build traffic to Claude API. $0/token benefit lost; delivery pipeline uninterrupted.&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-minio-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#1A1200;strokeColor=#F59E0B;strokeWidth=2;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="865" y="398" width="210" height="90" as="geometry" />
          <UserObject label="&lt;b style='font-size:10px'&gt;MinIO&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;distributed mode · erasure coding&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; node fails&lt;br/&gt;&lt;b&gt;Recovery:&lt;/b&gt; EC reconstructs data; artifact latency only&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-t2-note" parent="1" vertex="1"
          style="rounded=1;arcSize=6;fillColor=#1C1200;strokeColor=#F59E0B;strokeWidth=1;fontColor=#94A3B8;fontSize=8;align=left;spacingLeft=8;">
          <mxGeometry x="425" y="502" width="650" height="64" as="geometry" />
          <UserObject label="&lt;b style='color:#F59E0B'&gt;On gate component failure (MASS / Harbor):&lt;/b&gt; Gate waits with configurable timeout. If component does not recover, a signed human override is required. Override is written to PeaRL audit log with operator identity, timestamp, and justification. No silent bypasses." />
        </mxCell>

        <!-- ── TIER 3: GRACEFUL DEGRADE ── -->
        <mxCell id="p2-t3-bg" parent="1" vertex="1"
          style="rounded=1;arcSize=2;fillColor=#0A0B0F;strokeColor=#475569;strokeWidth=2;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#94A3B8;spacingTop=6;"
          value="◆  GRACEFUL DEGRADE">
          <mxGeometry x="1110" y="70" width="370" height="510" as="geometry" />
        </mxCell>
        <mxCell id="p2-tempo-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#0F1520;strokeColor=#475569;strokeWidth=1;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;">
          <mxGeometry x="1125" y="100" width="340" height="105" as="geometry" />
          <UserObject label="&lt;b style='font-size:10px'&gt;Grafana Tempo&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;OTel SDK buffered exporters · retry queue&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; collector outage&lt;br/&gt;&lt;b&gt;Effect:&lt;/b&gt; spans buffered in SDK memory&lt;br/&gt;Audit gaps possible. Pipeline continues — non-blocking.&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-github-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#0F1520;strokeColor=#475569;strokeWidth=1;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;">
          <mxGeometry x="1125" y="218" width="340" height="110" as="geometry" />
          <UserObject label="&lt;b style='font-size:10px'&gt;GitHub&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;graceful pause · optional Gitea/Forgejo mirror&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; GitHub outage&lt;br/&gt;&lt;b&gt;Effect:&lt;/b&gt; factory pauses at ⑦ PUBLISH&lt;br/&gt;Work queues. No data loss.&lt;br/&gt;Gitea mirror option for continuity.&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-massstream-r" parent="1" vertex="1"
          style="rounded=1;arcSize=8;fillColor=#0F1520;strokeColor=#475569;strokeWidth=1;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;">
          <mxGeometry x="1125" y="342" width="340" height="120" as="geometry" />
          <UserObject label="&lt;b style='font-size:10px'&gt;MASS Streaming (Mode 3)&lt;/b&gt;&lt;br/&gt;&lt;font color='#94A3B8' style='font-size:8px'&gt;health watchdog · SPEC.md re-read on restart&lt;/font&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;&lt;b&gt;Fail:&lt;/b&gt; stream interrupted&lt;br/&gt;&lt;b&gt;Effect:&lt;/b&gt; hard guardrails still fire (synchronous)&lt;br/&gt;Drift goes undetected until restart.&lt;br/&gt;On restart: re-reads SPEC.md baseline,&lt;br/&gt;resumes from latest OTel span.&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-t3-note" parent="1" vertex="1"
          style="rounded=1;arcSize=6;fillColor=#0A0C12;strokeColor=#334155;strokeWidth=1;fontColor=#64748B;fontSize=8;align=left;spacingLeft=8;">
          <mxGeometry x="1125" y="476" width="340" height="90" as="geometry" />
          <UserObject label="These components are NOT pipeline-blocking. On failure, delivery continues with reduced capability. Gaps are recorded. No component in the critical path (steps ①–⑧) lacks a defined recovery mechanism." />
        </mxCell>

        <!-- ── AWS MANAGED HA ── -->
        <mxCell id="p2-aws-bg" parent="1" vertex="1"
          style="rounded=1;arcSize=2;fillColor=#04041A;strokeColor=#818CF8;strokeWidth=2;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#818CF8;spacingTop=5;"
          value="◆  MANAGED HA — AWS (inherent multi-AZ resilience, no additional action required)">
          <mxGeometry x="40" y="592" width="1440" height="108" as="geometry" />
        </mxCell>
        <mxCell id="p2-aws1" parent="1" vertex="1" style="rounded=1;arcSize=8;fillColor=#10102A;strokeColor=#818CF8;strokeWidth=1;fontColor=#E2E8F0;fontSize=9;">
          <mxGeometry x="58" y="618" width="260" height="70" as="geometry" />
          <UserObject label="&lt;b&gt;AgentCore Runtime&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:8px'&gt;microVM per session · managed scaling&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-aws2" parent="1" vertex="1" style="rounded=1;arcSize=8;fillColor=#10102A;strokeColor=#818CF8;strokeWidth=1;fontColor=#E2E8F0;fontSize=9;">
          <mxGeometry x="330" y="618" width="260" height="70" as="geometry" />
          <UserObject label="&lt;b&gt;ASM + KMS&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:8px'&gt;multi-AZ secrets · post-quantum KMS&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-aws3" parent="1" vertex="1" style="rounded=1;arcSize=8;fillColor=#10102A;strokeColor=#818CF8;strokeWidth=1;fontColor=#E2E8F0;fontSize=9;">
          <mxGeometry x="602" y="618" width="260" height="70" as="geometry" />
          <UserObject label="&lt;b&gt;AgentCore Gateway&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:8px'&gt;PeaRL OpenAPI → MCP · managed LB&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-aws4" parent="1" vertex="1" style="rounded=1;arcSize=8;fillColor=#10102A;strokeColor=#818CF8;strokeWidth=1;fontColor=#E2E8F0;fontSize=9;">
          <mxGeometry x="874" y="618" width="260" height="70" as="geometry" />
          <UserObject label="&lt;b&gt;X-Ray + CodeArtifact&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:8px'&gt;distributed tracing · private registry&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p2-aws5" parent="1" vertex="1" style="rounded=1;arcSize=8;fillColor=#10102A;strokeColor=#818CF8;strokeWidth=1;fontColor=#E2E8F0;fontSize=9;">
          <mxGeometry x="1146" y="618" width="260" height="70" as="geometry" />
          <UserObject label="&lt;b&gt;Cedar Policy + IAM Roles Anywhere&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:8px'&gt;AWS infra guardrails · SPIRE federation&lt;/font&gt;" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

