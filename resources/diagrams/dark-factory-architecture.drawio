        <mxCell id="p4-g3-in" parent="1" vertex="1" style="rounded=1;arcSize=6;fillColor=#1E1B4B;strokeColor=#6366F1;strokeWidth=1;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;">
          <mxGeometry x="1000" y="158" width="460" height="40" as="geometry" /><UserObject label="&lt;b&gt;Inputs:&lt;/b&gt; PR diff · SPEC.md · PeaRL task packet · trace_id" />
