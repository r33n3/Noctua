  ═══════════════════════════════════════════════════════════════════ -->
  <diagram id="p4-security" name="Security Gates">
    <mxGraphModel grid="1" gridSize="10" pageWidth="1540" pageHeight="740">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

