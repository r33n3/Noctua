        <mxCell id="p4-g1-e-yes" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EF4444;strokeWidth=2;endArrow=block;endFill=1;fontSize=8;fontColor=#EF4444;" value="YES" source="p4-g1-dec" target="p4-g1-yes">
