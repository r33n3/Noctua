        </mxCell>

        <!-- ── GATE 1: PRE-FLIGHT ── -->
        <mxCell id="p4-g1-bg" parent="1" vertex="1"
          style="rounded=1;arcSize=2;fillColor=#120000;strokeColor=#EF4444;strokeWidth=2;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#EF4444;spacingTop=8;"
          value="GATE 1 — PRE-FLIGHT (T=0)">
