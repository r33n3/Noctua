        <mxCell id="p4-g2-hard" parent="1" vertex="1" style="rounded=1;arcSize=8;fillColor=#3B0000;strokeColor=#EF4444;strokeWidth=2;fontColor=#F87171;fontSize=9;align=left;spacingLeft=8;">
