        <mxCell id="p4-g3-mass" parent="1" vertex="1" style="rounded=1;arcSize=6;fillColor=#2A0000;strokeColor=#EF4444;strokeWidth=2;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="1000" y="212" width="460" height="70" as="geometry" />
          <UserObject label="&lt;b&gt;MASS 2.0 — Mode 2 (delivery gate)&lt;/b&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;All 4 agents scan PR diff: vuln, redteam, supply chain, trajectory. Findings → pearl_submit_findings&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p4-g3-harbor" parent="1" vertex="1" style="rounded=1;arcSize=6;fillColor=#1C1A3B;strokeColor=#818CF8;strokeWidth=2;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="1000" y="294" width="460" height="70" as="geometry" />
          <UserObject label="&lt;b&gt;deepagents-harbor — Correctness Gate&lt;/b&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;Reads SPEC.md acceptance criteria. Evaluates agent output per criterion. Score + pass/fail → PeaRL gate.&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p4-g3-pearl-g" parent="1" vertex="1" style="rounded=1;arcSize=6;fillColor=#1C1A3B;strokeColor=#818CF8;strokeWidth=2;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="1000" y="376" width="460" height="60" as="geometry" />
          <UserObject label="&lt;b&gt;PeaRL — Governance Gate&lt;/b&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;Allowance Profile compliance · budget check · promotion gate decision&lt;/font&gt;" />
        </mxCell>

        <mxCell id="p4-g3-dec" parent="1" vertex="1"
          style="rhombus;fillColor=#1A1A2A;strokeColor=#818CF8;strokeWidth=2;fontColor=#A5B4FC;fontSize=9;align=center;verticalAlign=middle;fontStyle=1;">
          <mxGeometry x="1110" y="450" width="200" height="55" as="geometry" /><UserObject label="All three pass?" />
        </mxCell>

        <mxCell id="p4-g3-block" parent="1" vertex="1" style="rounded=1;arcSize=8;fillColor=#3B0000;strokeColor=#EF4444;strokeWidth=2;fontColor=#F87171;fontSize=9;align=left;spacingLeft=8;">
          <mxGeometry x="1000" y="530" width="195" height="50" as="geometry" />
          <UserObject label="&lt;b style='color:#EF4444'&gt;BLOCK&lt;/b&gt; — PR merge blocked. Findings in PeaRL. Agent or human fixes and re-runs gate." />
        </mxCell>
        <mxCell id="p4-g3-e-block" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EF4444;strokeWidth=2;endArrow=block;endFill=1;fontSize=8;fontColor=#EF4444;" value="NO" source="p4-g3-dec" target="p4-g3-block">
