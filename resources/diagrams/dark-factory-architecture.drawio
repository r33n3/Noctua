        <!-- Bottom properties bar -->
        <mxCell id="p4-props-bg" parent="1" vertex="1"
          style="rounded=1;arcSize=3;fillColor=#0B0F1A;strokeColor=#334155;strokeWidth=1;verticalAlign=top;fontSize=10;fontStyle=1;fontColor=#64748B;spacingTop=6;"
          value="KEY PROPERTIES">
          <mxGeometry x="40" y="604" width="1440" height="118" as="geometry" />
        </mxCell>
        <mxCell id="p4-p1" parent="1" vertex="1" style="rounded=1;arcSize=6;fillColor=#0F1520;strokeColor=#1E293B;fontColor=#94A3B8;fontSize=9;align=left;spacingLeft=8;">
          <mxGeometry x="58" y="628" width="320" height="80" as="geometry" />
          <UserObject label="&lt;b style='color:#E2E8F0'&gt;Gates are independent&lt;/b&gt;&lt;br/&gt;Gate 1 and Gate 3 MASS runs are separate invocations. Gate 2 is continuous async streaming. Each gate has its own findings record in PeaRL." />
        </mxCell>
        <mxCell id="p4-p2" parent="1" vertex="1" style="rounded=1;arcSize=6;fillColor=#0F1520;strokeColor=#1E293B;fontColor=#94A3B8;fontSize=9;align=left;spacingLeft=8;">
          <mxGeometry x="390" y="628" width="320" height="80" as="geometry" />
          <UserObject label="&lt;b style='color:#E2E8F0'&gt;Gate 2 never blocks the hot path&lt;/b&gt;&lt;br/&gt;Drift detection is fully async. Hard guardrails are synchronous. The performance cost of Gate 2 is near-zero on the critical execution path." />
        </mxCell>
        <mxCell id="p4-p3" parent="1" vertex="1" style="rounded=1;arcSize=6;fillColor=#0F1520;strokeColor=#1E293B;fontColor=#94A3B8;fontSize=9;align=left;spacingLeft=8;">
          <mxGeometry x="722" y="628" width="320" height="80" as="geometry" />
          <UserObject label="&lt;b style='color:#E2E8F0'&gt;Gate 3 requires all three to pass&lt;/b&gt;&lt;br/&gt;MASS pass AND Harbor pass AND PeaRL governance approval. Any failure blocks merge. No partial pass. No component can be skipped." />
        </mxCell>
        <mxCell id="p4-p4" parent="1" vertex="1" style="rounded=1;arcSize=6;fillColor=#0F1520;strokeColor=#1E293B;fontColor=#94A3B8;fontSize=9;align=left;spacingLeft=8;">
          <mxGeometry x="1054" y="628" width="400" height="80" as="geometry" />
          <UserObject label="&lt;b style='color:#E2E8F0'&gt;No silent bypass — ever&lt;/b&gt;&lt;br/&gt;Override requires: signed human identity + justification text + written to PeaRL immutable audit log. Override is visible in SSE dashboard. MASS/Harbor auto-restart before override is considered." />
        </mxCell>

