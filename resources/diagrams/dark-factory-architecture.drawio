          <mxGeometry x="75" y="228" width="370" height="90" as="geometry" />
          <UserObject label="&lt;b&gt;MASS 2.0 — Mode 1 (meta-scan)&lt;/b&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;static-analysis:8001 — code/text injection, secrets in spec&lt;br/&gt;redteam:8002 — adversarial prompt detection&lt;br/&gt;mcp-security:8003 — tool scope validation&lt;br/&gt;All findings → pearl_submit_findings&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p4-g1-arr2" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EF4444;strokeWidth=2;endArrow=block;endFill=1;" value="" source="p4-g1-scan" target="p4-g1-dec">
