        </mxCell>
        <mxCell id="p4-g1-arr1" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EF4444;strokeWidth=2;endArrow=block;endFill=1;" value="" source="p4-g1-in" target="p4-g1-scan">
