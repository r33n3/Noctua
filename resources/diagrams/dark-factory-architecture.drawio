        <mxCell id="p4-g3-arr4" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#818CF8;strokeWidth=1;endArrow=block;endFill=1;" value="" source="p4-g3-pearl-g" target="p4-g3-dec">
