          <mxGeometry x="545" y="158" width="370" height="52" as="geometry" /><UserObject label="&lt;b&gt;Inputs:&lt;/b&gt; SPEC.md as behavioral baseline&lt;br/&gt;Every @before_tool fires a behavioral packet" />
        </mxCell>
        <mxCell id="p4-g2-arr1" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F59E0B;strokeWidth=2;endArrow=block;endFill=1;" value="" source="p4-g2-in" target="p4-g2-scan">
