        <mxCell id="p4-g2-scan" parent="1" vertex="1" style="rounded=1;arcSize=6;fillColor=#1A1200;strokeColor=#F59E0B;strokeWidth=2;fontColor=#E2E8F0;fontSize=9;align=left;spacingLeft=8;shadow=1;">
          <mxGeometry x="545" y="228" width="370" height="90" as="geometry" />
          <UserObject label="&lt;b&gt;MASS 2.0 — Mode 3 (streaming diagnostics)&lt;/b&gt;&lt;hr/&gt;&lt;font style='font-size:8px'&gt;diagnostics:8004 — trajectory analysis&lt;br/&gt;Bro/Zeek pattern matching on tool call sequence&lt;br/&gt;Compares against SPEC.md action scope baseline&lt;br/&gt;ASYNC — does NOT block the hot path&lt;/font&gt;" />
        </mxCell>
        <mxCell id="p4-g2-arr2" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F59E0B;strokeWidth=2;endArrow=block;endFill=1;" value="" source="p4-g2-scan" target="p4-g2-dec">
